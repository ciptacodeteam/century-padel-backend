# App
NODE_ENV=development
PORT=8000
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

FRONT_END_URL=http://localhost:3000

LOG_LEVEL=debug

STORAGE_STRATEGY=local # options: local, blob

# DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/century_padel?schema=public

# Redis (optional for rate limiter)
REDIS_URL=redis://localhost:6379

# JWT
# Generate secret from https://www.better-auth.com/docs/installation#install-the-package
JWT_SECRET=replace
JWT_REFRESH_SECRET=replace
JWT_ISSUER=booking-api
JWT_AUDIENCE=booking-client
JWT_EXPIRES=60
JWT_REFRESH_EXPIRES=30

# Payments / Webhooks (Xendit)
XENDIT_API_KEY=replace
XENDIT_CALLBACK_TOKEN=replace  # header: x-callback-token
WEBHOOK_BASE_URL=http://localhost:8787/webhooks

# Ngrok Configuration for Webhook Testing
# Get your auth token from: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=replace_with_your_ngrok_authtoken

# Optional: Custom ngrok domain (paid plans only)
# If you have a paid plan, you can use a custom subdomain
# Example: myapp.ngrok-free.app or custom domain
NGROK_DOMAIN=

# Webhook configuration - will be auto-updated by ngrok
WEBHOOK_BASE_URL=http://localhost:8000/webhooks

# Set to false if you have a paid ngrok plan
NGROK_FREE_PLAN=true

# Fazpass (for phone number authentication)
# Refer to https://dashboard.fazpass.com/integration
FAZPASS_MERCHANT_KEY=replace
FAZPASS_GATEWAY_KEY=replace
FAZPASS_API_URL=https://api.fazpass.com/v1

# Password Pepper (for additional security on password hashing)
PWD_PEPPER=dZbgXKciu1IzhnC80jHuRmxYgIiq61v8

# BLOB Storage (for file uploads)
BLOB_READ_WRITE_TOKEN=replace

# Email (Resend) — https://resend.com
RESEND_API_KEY=replace
RESEND_FROM="Century Padel <onboarding@resend.dev>"
BACKUP_ALERT_EMAIL=ciptacodeteam@gmail.com