# ============================================
# Production Environment Variables Template
# ============================================
# Copy this file to .env.production in the project root and fill in your actual values
# DO NOT commit .env.production to version control

# --------------------------------------------
# Node Environment
# --------------------------------------------
NODE_ENV=production

# --------------------------------------------
# Application
# --------------------------------------------
PORT=3000
APP_NAME="Quantum Sport"
APP_URL=https://your-domain.com

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# IMPORTANT: Fill these values before deploying
DB_NAME=quantum_sport
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Full database URL (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connection_limit=10&pool_timeout=20

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --------------------------------------------
# JWT & Security
# --------------------------------------------
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=30d

# --------------------------------------------
# Email Configuration (SMTP)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# --------------------------------------------
# Payment Gateway (Xendit)
# --------------------------------------------
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token
XENDIT_PUBLIC_KEY=your_xendit_public_key

# --------------------------------------------
# File Storage (Vercel Blob)
# --------------------------------------------
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# --------------------------------------------
# Frontend URL (for CORS)
# --------------------------------------------
FRONTEND_URL=https://your-frontend-domain.com

# --------------------------------------------
# Optional: Monitoring & Logging
# --------------------------------------------
# SENTRY_DSN=your_sentry_dsn
# LOG_LEVEL=info

# --------------------------------------------
# Optional: SMS/Phone Verification
# --------------------------------------------
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

