# ============================================
# Production Environment Variables Template
# ============================================
# Fresh VPS setup:
#   1. ./scripts/install-vps.sh
#   2. cp docker/env.production.template .env.production && nano .env.production
#   3. ./scripts/deploy-fresh.sh
# Routine updates: ./scripts/update.sh
# DO NOT commit .env.production to version control

# --------------------------------------------
# Node Environment
# --------------------------------------------
NODE_ENV=production

# --------------------------------------------
# Application
# --------------------------------------------
PORT=8000
APP_NAME="Century Padel"
APP_URL=https://api.centurypadel.id
BASE_URL=https://api.centurypadel.id

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# IMPORTANT: Fill these values before deploying
DB_NAME=century_padel
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Full database URL (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connection_limit=10&pool_timeout=20

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --------------------------------------------
# JWT & Security
# --------------------------------------------
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=century-padel-backend
JWT_AUDIENCE=century-padel-frontend

# --------------------------------------------
# Email Configuration (SMTP)
# --------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# --------------------------------------------
# Payment Gateway (Xendit)
# --------------------------------------------
XENDIT_SECRET_KEY=your_xendit_secret_key
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_token
XENDIT_PUBLIC_KEY=your_xendit_public_key

# --------------------------------------------
# File Storage (Vercel Blob)
# --------------------------------------------
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# --------------------------------------------
# Frontend URL (for CORS)
# --------------------------------------------
FRONT_END_URL=https://centurypadel.id
CORS_ORIGINS=https://centurypadel.id,https://www.centurypadel.id

# --------------------------------------------
# SSL Configuration (for Let's Encrypt)
# --------------------------------------------
SSL_DOMAIN=api.centurypadel.id
SSL_EMAIL=admin@centurypadel.id

# --------------------------------------------
# Optional: Monitoring & Logging
# --------------------------------------------
# SENTRY_DSN=your_sentry_dsn
# LOG_LEVEL=info

# --------------------------------------------
# Optional: SMS/Phone Verification
# --------------------------------------------
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=your_twilio_phone_number

