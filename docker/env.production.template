# ============================================
# Production Environment Variables Template
# ============================================
# Fresh VPS setup:
#   1. ./scripts/install-vps.sh
#   2. cp docker/env.production.template .env.production && nano .env.production
#   3. ./scripts/deploy-fresh.sh
# Routine updates: ./scripts/update.sh
# DO NOT commit .env.production to version control

# --------------------------------------------
# Node Environment
# --------------------------------------------
NODE_ENV=production

# --------------------------------------------
# Application
# --------------------------------------------
PORT=8000
APP_NAME="Century Padel"
APP_URL=https://api.centurypadelid.com
BASE_URL=https://api.centurypadelid.com
WEBHOOK_BASE_URL=https://api.centurypadelid.com/webhooks

# --------------------------------------------
# Database Configuration
# --------------------------------------------
# IMPORTANT: Fill these values before deploying
DB_NAME=century_padel
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Full database URL (auto-constructed in docker-compose)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public&connection_limit=10&pool_timeout=20

# --------------------------------------------
# Redis Configuration
# --------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# --------------------------------------------
# JWT & Security
# --------------------------------------------
JWT_SECRET=your_jwt_secret_min_32_chars_here
JWT_EXPIRES=10080
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_here
JWT_REFRESH_EXPIRES=30
JWT_ISSUER=century-padel-backend
JWT_AUDIENCE=century-padel-frontend

# --------------------------------------------
# Email (Resend) — https://resend.com
# --------------------------------------------
# Verify your sending domain in Resend before going live.
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM=Century Padel <noreply@centurypadel.id>
BACKUP_ALERT_EMAIL=ciptacodeteam@gmail.com

# --------------------------------------------
# Payment Gateway (Xendit)
# --------------------------------------------
XENDIT_API_KEY=your_xendit_api_key
XENDIT_CALLBACK_TOKEN=your_xendit_webhook_token

# --------------------------------------------
# Phone OTP (Fazpass) — required for app startup
# https://dashboard.fazpass.com/integration
# --------------------------------------------
FAZPASS_MERCHANT_KEY=your_fazpass_merchant_key
FAZPASS_GATEWAY_KEY=your_fazpass_gateway_key
FAZPASS_API_URL=https://api.fazpass.com/v1

# --------------------------------------------
# File Storage (Vercel Blob)
# --------------------------------------------
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# --------------------------------------------
# Frontend URL (for CORS)
# --------------------------------------------
FRONT_END_URL=https://centurypadel.id
CORS_ORIGINS=https://centurypadel.id,https://www.centurypadel.id

# --------------------------------------------
# SSL Configuration (for Let's Encrypt)
# --------------------------------------------
SSL_DOMAIN=api.centurypadelid.com
SSL_EMAIL=admin@centurypadelid.com

# --------------------------------------------
# Database Backup (DigitalOcean Spaces)
# --------------------------------------------
# Isolated prefix — does not touch other folders in the bucket (account/, kta/, main/)
# Create keys: DigitalOcean → API → Spaces access keys
SPACES_BUCKET=kms-data
SPACES_REGION=sgp1
SPACES_PREFIX=century-padel/db
SPACES_ACCESS_KEY=your_spaces_access_key
SPACES_SECRET_KEY=your_spaces_secret_key
BACKUP_RETENTION_DAYS=30

# --------------------------------------------
# Optional: Monitoring & Logging
# --------------------------------------------
# SENTRY_DSN=your_sentry_dsn
# LOG_LEVEL=info

